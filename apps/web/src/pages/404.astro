---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Page Not Found">
  <div class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-5 md:px-8 text-center">
      <h1 class="text-4xl font-bold mb-4">Page Not Found</h1>
      <p class="text-[var(--color-text-muted)] mb-8">The page you are looking for does not exist.</p>
      <a href="/" class="text-[var(--color-primary)] hover:underline">&larr; Back to ProductBuildersHQ</a>
    </div>
  </div>
</BaseLayout>
