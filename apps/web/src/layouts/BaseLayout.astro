---
import '../styles/global.css'
import navConfig from '../config/nav-config.json'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'ProductBuildersHQ',
  description = 'Frameworks and case studies for the evolution of product development in the age of AI.',
} = Astro.props

const pageTitle = title === 'ProductBuildersHQ' ? title : `${title} | ProductBuildersHQ`
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
const year = new Date().getFullYear()
const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, '') || '/'
  return normalized === '/' ? currentPath === '/' : currentPath.startsWith(normalized)
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <nav class="sticky top-0 z-50 bg-[var(--color-frame-bg)]">
        <div class="max-w-7xl mx-auto px-5 md:px-8">
          <div class="flex items-center justify-between h-16">
            <a href="/" class="flex items-center gap-2 no-underline">
              <span class="text-xl font-bold text-[var(--color-frame-text)]">{navConfig.brand.name}</span>
            </a>

            <div class="hidden md:flex items-center gap-6">
              {navConfig.links.map((link) => (
                <a
                  href={link.href}
                  class:list={[
                    'text-sm font-medium no-underline transition-colors',
                    isActive(link.href)
                      ? 'text-[var(--color-frame-accent)]'
                      : 'text-[var(--color-frame-text-muted)] hover:text-[var(--color-frame-text)]',
                  ]}
                >
                  {link.label}
                </a>
              ))}
              {navConfig.dropdowns.map((dropdown) => (
                <div class="relative group">
                  <button class="flex items-center gap-1 text-sm font-medium text-[var(--color-frame-text-muted)] group-hover:text-[var(--color-frame-text)] transition-colors bg-transparent border-none cursor-pointer">
                    {dropdown.label}
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                  </button>
                  <div class="absolute top-full left-0 mt-2 w-64 bg-[var(--color-frame-bg)] border border-[rgba(255,255,255,0.15)] rounded-lg shadow-lg py-2 z-50 hidden group-hover:block group-focus-within:block">
                    {dropdown.items.map((item) => (
                      <a
                        href={item.href}
                        target={item.external ? '_blank' : undefined}
                        rel={item.external ? 'noopener noreferrer' : undefined}
                        class="block px-4 py-2 text-sm text-[var(--color-frame-text-muted)] hover:text-[var(--color-frame-text)] hover:bg-[rgba(255,255,255,0.05)] no-underline"
                      >
                        <div class="font-medium">{item.label}</div>
                        {item.description && <div class="text-xs text-[var(--color-frame-text-muted)] mt-0.5">{item.description}</div>}
                      </a>
                    ))}
                  </div>
                </div>
              ))}
              {navConfig.actions.map((action) => (
                <a
                  href={action.href}
                  target={action.external ? '_blank' : undefined}
                  rel={action.external ? 'noopener noreferrer' : undefined}
                  class="text-[var(--color-frame-text-muted)] hover:text-[var(--color-frame-text)] transition-colors"
                  title={action.label}
                  aria-label={action.label}
                >
                  {action.icon === 'github' ? (
                    <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor" aria-hidden="true">
                      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"></path>
                    </svg>
                  ) : action.label}
                </a>
              ))}
            </div>

            <details class="md:hidden relative">
              <summary class="list-none text-[var(--color-frame-text)] cursor-pointer p-2" aria-label="Open navigation">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
              </summary>
              <div class="absolute right-0 top-full mt-3 w-72 bg-[var(--color-frame-bg)] border border-[rgba(255,255,255,0.15)] rounded-lg shadow-lg p-4">
                <div class="flex flex-col gap-4">
                  {navConfig.links.map((link) => (
                    <a href={link.href} class:list={['text-sm font-medium no-underline', isActive(link.href) ? 'text-[var(--color-frame-accent)]' : 'text-[var(--color-frame-text-muted)]']}>
                      {link.label}
                    </a>
                  ))}
                  {navConfig.dropdowns.map((dropdown) => (
                    <div class="border-t border-[rgba(255,255,255,0.1)] pt-4">
                      <div class="text-xs text-[var(--color-frame-text-muted)] uppercase tracking-wide mb-2">{dropdown.label}</div>
                      {dropdown.items.map((item) => (
                        <a href={item.href} class="block py-2 text-sm text-[var(--color-frame-text-muted)] no-underline">{item.label}</a>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            </details>
          </div>
        </div>
      </nav>

      <main class="flex-1">
        <slot />
      </main>

      <footer class="bg-[var(--color-frame-bg)] text-[var(--color-frame-text)] py-12">
        <div class="max-w-7xl mx-auto px-5 md:px-8">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
              <h3 class="text-lg font-bold mb-4">ProductBuildersHQ</h3>
              <p class="text-[var(--color-frame-text-muted)] text-sm">Frameworks and case studies for the evolution of product development.</p>
            </div>
            <div>
              <h4 class="text-sm font-semibold uppercase tracking-wider mb-4 text-[var(--color-frame-accent)]">Research</h4>
              <ul class="space-y-2">
                <li><a href="/frameworks" class="text-[var(--color-frame-text-muted)] hover:text-[var(--color-frame-text)] text-sm no-underline">Frameworks</a></li>
                <li><a href="/case-studies" class="text-[var(--color-frame-text-muted)] hover:text-[var(--color-frame-text)] text-sm no-underline">Case Studies</a></li>
              </ul>
            </div>
            <div>
              <h4 class="text-sm font-semibold uppercase tracking-wider mb-4 text-[var(--color-frame-accent)]">Company</h4>
              <ul class="space-y-2">
                <li><a href="/about" class="text-[var(--color-frame-text-muted)] hover:text-[var(--color-frame-text)] text-sm no-underline">About</a></li>
                <li><a href="https://github.com/ProductBuildersHQ" target="_blank" rel="noopener noreferrer" class="text-[var(--color-frame-text-muted)] hover:text-[var(--color-frame-text)] text-sm no-underline">GitHub</a></li>
              </ul>
            </div>
          </div>
          <div class="mt-12 pt-8 border-t border-[var(--color-frame-border)] text-center text-[var(--color-frame-text-muted)] text-sm">
            <span class="text-[var(--color-frame-accent)]">productbuildershq.com</span>
            <span class="mx-2">&middot;</span>
            &copy; {year} ProductBuildersHQ
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
